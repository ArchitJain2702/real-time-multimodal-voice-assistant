# .env.example
# MongoDB
MONGODB_URI=mongodb://localhost:27017/voice_assistant

# Redis
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Server
SERVER_PORT=8080
WEBSOCKET_PORT=8081

# Deepgram
DEEPGRAM_API_KEY=your_deepgram_api_key

# Groq
GROQ_API_KEY=your_groq_api_key

# Cartesia
CARTESIA_API_KEY=your_cartesia_api_key
